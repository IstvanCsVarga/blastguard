# Auth0
AUTH0_SECRET=generate-with-openssl-rand-hex-32
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.us.auth0.com
AUTH0_CLIENT_ID=YOUR_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_CLIENT_SECRET

# Auth0 API
AUTH0_AUDIENCE=https://blastguard.local/api

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Demo repo for GitHub investigation (public repos work without auth)
DEMO_REPO_OWNER=netbirdio
DEMO_REPO_NAME=netbird

# OpenFGA (optional - app works with local SQLite-based FGA tracking)
FGA_STORE_ID=
FGA_API_URL=https://api.us1.fga.dev
FGA_CLIENT_ID=
FGA_CLIENT_SECRET=
